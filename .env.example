# ============================================================
# IFFLOW — variáveis de ambiente
# ============================================================
# Este é o .env.example. Copie para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.
#
# O .env único na raiz do monorepo é lido por:
#   - apps/backend (via pydantic-settings)
#   - apps/frontend (via Vite, apenas variáveis VITE_*)
# ============================================================


# ------------------------------------------------------------
# GERAL
# ------------------------------------------------------------

# Ambiente de execução: development | test | production
ENVIRONMENT=development


# ------------------------------------------------------------
# BANCO DE DADOS
# ------------------------------------------------------------

# String de conexão do Postgres.
# Em dev, aponta para o container do docker-compose.
# Em prod, vem do painel do Railway/Render.
DATABASE_URL=postgresql://ifflow:ifflow_dev_password@localhost:5432/ifflow

# Credenciais usadas pelo docker-compose para criar o banco local.
# Estas duas variáveis são lidas APENAS pelo docker-compose.yml — o backend
# usa DATABASE_URL acima.
POSTGRES_USER=ifflow
POSTGRES_PASSWORD=ifflow_dev_password
POSTGRES_DB=ifflow


# ------------------------------------------------------------
# SEGURANÇA — BACKEND
# ------------------------------------------------------------

# Chave de assinatura do JWT. Mínimo 32 bytes aleatórios.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NUNCA reuse entre ambientes. NUNCA commite.
JWT_SECRET=change-me-to-a-32-byte-random-string-generated-with-secrets-module

# Tempo de expiração do JWT em horas. Default: 24h.
JWT_EXPIRATION_HOURS=24


# ------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------

# Chave da API do Resend. Obtenha em: https://resend.com/api-keys
# Em dev, pode deixar vazio — o backend detecta ENVIRONMENT=development
# e grava emails em memória em vez de enviar de verdade.
RESEND_API_KEY=

# Email remetente. Em dev pode ser qualquer coisa.
# Em prod, precisa ser um domínio verificado no Resend.
EMAIL_FROM="IFFLOW <noreply@ifflow.local>"


# ------------------------------------------------------------
# CORS — BACKEND
# ------------------------------------------------------------

# URL do frontend para liberar CORS. Em dev: Vite padrão.
# Em prod, a URL real do deploy (ex: https://ifflow.vercel.app)
FRONTEND_URL=http://localhost:5173


# ------------------------------------------------------------
# SEED DO SUPER_ADMIN INICIAL
# ------------------------------------------------------------
# Usado APENAS pelo script app/scripts/seed_super_admin.py.
# Rode uma única vez no primeiro setup de cada ambiente.
# Depois de criado, pode apagar essas variáveis se quiser.

SEED_SUPER_ADMIN_EMAIL=superadmin@ifam.edu.br
SEED_SUPER_ADMIN_PASSWORD=change-me-on-first-login
SEED_SUPER_ADMIN_NAME="Super Administrador"
SEED_SUPER_ADMIN_SIAPE=0000000


# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
# Apenas variáveis com prefixo VITE_* são expostas ao frontend.
# Tudo que não começa com VITE_ fica acessível SÓ ao backend.

# URL do backend para o frontend chamar.
# Em dev: backend local. Em prod: URL real do Railway/Render.
VITE_API_URL=http://localhost:8000
